{
  "name": "css-mutator",
  "version": "0.1.0",
  "description": "CSS mutation testing for Vite + Vitest — catch visual bugs before your users do",
  "keywords": [
    "css",
    "mutation-testing",
    "visual-testing",
    "vite",
    "vitest"
  ],
  "license": "LGPL-3.0-or-later",
  "bin": {
    "css-mutate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "postcss": "^8.4.49",
    "postcss-value-parser": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0",
    "vitest": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  }
}
